{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Swap Esc and ` (Esc function switches to English)",
                        "manipulators": [
                            {
                                "description": "` -> Escape + English (백틱 키를 누르면 ESC와 동시에 영문 전환)",
                                "from": {
                                    "key_code": "grave_accent_and_tilde",
                                    "modifiers": { "optional": ["caps_lock"] }
                                },
                                "to": [
                                    { "key_code": "escape" },
                                    { "select_input_source": { "input_source_id": "^com\\.apple\\.keylayout\\.ABC$" } }
                                ],
                                "type": "basic"
                            },
                            {
                                "description": "Escape -> ` (물리적 Esc 키를 누르면 백틱 입력)",
                                "from": {
                                    "key_code": "escape",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "grave_accent_and_tilde" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Caps Lock to Control (Use Shift+Caps to Toggle Caps Lock)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": {
                                        "mandatory": ["left_control"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [{ "key_code": "caps_lock" }],
                                "type": "basic"
                            },
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "left_control" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Cmd+J to Launch IntelliJ IDEA",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "j",
                                    "modifiers": {
                                        "mandatory": ["left_command"]
                                    }
                                },
                                "to": [
                                    {
                                        "shell_command": "open '/Users/sam/Applications/IntelliJ IDEA.app'"
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Right Command to F18 (한영키로 사용)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "right_command",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [{ "key_code": "f18" }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
